# CoachLoop environment variables — fork-and-run.
# Copy to .env and fill in all four. NEVER commit your real .env.
# The whole app runs on YOUR own Anthropic + ElevenLabs accounts.

# Anthropic — Opus 4.8 scoring/coaching/re-score. https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs — realtime voice drill (the AI prospect). https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...
# The ElevenLabs Agent configured with Claude as the LLM (the "AI prospect").
ELEVENLABS_AGENT_ID=agent_...

# Neon Postgres connection string (free tier is enough). https://neon.tech/
# When set, uploaded calls persist to Neon; when unset, they use an in-memory
# fallback so the loop still runs (Feature 2). Tables bootstrap on first use.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth0 — OPTIONAL (Feature 3). The Session port runs as the seeded team until
# these are set; a missing tenant can never break the demo. The Auth0 adapter
# itself ships in a later batch — these are scaffolded now so wiring is a swap.
# https://auth0.com/
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=https://coachloop.vercel.app
