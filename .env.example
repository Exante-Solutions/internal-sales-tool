# Discovery Workspace — environment variables (SPEC §17).
# Copy to .env and fill in what you need. NEVER commit your real .env.
#
# OFFLINE-FIRST: every var below is OPTIONAL for local dev and verify.sh.
# When a var is unset the app degrades gracefully — seeded session, in-memory
# repos, and fake gateways (FakeSecretStore, FakeCalendarGateway, fake coach)
# keep the whole loop running with no keys and no DB. A var is only "required"
# for the [LIVE] gate it powers, noted per-block below.

# --- Core ------------------------------------------------------------------

# Neon Postgres connection string (Drizzle). https://neon.tech/
# Unset -> in-memory repositories (the loop still runs; data is not persisted).
# [LIVE persistence] required to persist conversations/prospects/profiles.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic — Opus 4.8 (claude-opus-4-8). On-demand playbook analysis,
# discovery fields, profile rollups, coaching add-on. https://console.anthropic.com/
# Unset -> fake coach adapter returns canned analysis offline.
# [LIVE analysis] required for real Claude scoring/coaching.
ANTHROPIC_API_KEY=sk-ant-...

# Public base URL for OAuth callbacks and webhooks.
# [LIVE auth/oauth/webhooks] required so callbacks resolve to this app.
APP_BASE_URL=http://localhost:3000
# App identifier used to namespace per-user secrets (SPEC §6.7, §17). Every
# secret is stored under /internal_tools/<APP_NAME>/<workspaceId>/<userId>/… in
# AWS Secrets Manager. Use a distinct value per environment (prod vs each dev)
# so secrets never collide. Unset -> falls back to AWS_SECRETS_PREFIX.
APP_NAME=...

# --- Auth0 (login + workspace identity) ------------------------------------
# Unset -> Session port runs as the seeded team; a missing tenant never breaks
# the demo. [LIVE auth] all four required to enable real login.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Cookie/session encryption secret for the Auth0 SDK (generate a long random string).
AUTH0_SECRET=
# Optional (SPEC §9, §18.2). Auth0 Organization id (org_...) to scope login to.
# v4 does NOT auto-read this — lib/auth0.ts passes it via authorizationParameters
# when set. With the tenant toggle "Allow Organization Names in Authentication
# API" on, the ID token then carries org_name → upserted onto team.name.
AUTH0_ORGANIZATION=
# Optional (SPEC §9, §18.2, §17 footnote ⁴). Namespaced ID-token claim the
# session reads for the workspace name shown in the nav. Unused if you use Auth0
# Organizations (org_name); else inject a post-login Action claim and name it
# here (see SPEC §17⁴ for the Action snippet). Falls back to DEFAULT_TEAM_NAME
# when unset.
AUTH0_WORKSPACE_NAME_CLAIM=

# --- Google (per-user Gmail + calendar data connection, NOT login) ---------
# Unset -> data-connection features use fakes/seeded data offline.
# [LIVE google] both required for the per-user Gmail/calendar OAuth connection.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google connection OAuth callback (must match the Google console redirect URI).
# [LIVE google] required. e.g. ${APP_BASE_URL}/api/connections/google/callback
GOOGLE_OAUTH_REDIRECT_URL=

# --- AWS Secrets Manager (per-user OAuth token storage) --------------------
# Unset (no AWS_* below) -> FakeSecretStore (in-memory) so OAuth/sync use cases
# run with no AWS. Setting AWS_PROFILE, AWS_REGION, AWS_ACCESS_KEY_ID, or
# AWS_KMS_KEY_ID switches on the live AwsSecretsManagerAdapter.
#
# Auth (pick ONE):
#  - LOCAL/SSO (recommended): set AWS_PROFILE and run `aws sso login --profile <name>`.
#    Region is read from the profile's config if AWS_REGION is unset.
#  - DEPLOYED: prefer an attached IAM role / the default credential chain (set
#    neither AWS_PROFILE nor explicit keys).
#  - Explicit keys (last resort): set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY.
# [LIVE oauth-storage]
AWS_PROFILE=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Customer-managed KMS key (ARN, key id, or alias/<name>) used to encrypt secrets
# at CreateSecret. Unset -> the account's default aws/secretsmanager key.
AWS_KMS_KEY_ID=
# Optional name/path prefix for created secrets (e.g. discovery/oauth/).
AWS_SECRETS_PREFIX=

# --- Calendar webhook (v1 live integration) --------------------------------
# Verify calendar webhook signatures. Offline tests use FakeCalendarGateway.
# [LIVE calendar] required in deployed environments.
CALENDAR_WEBHOOK_SECRET=

# --- ElevenLabs (voice drill — coaching add-on, carried) -------------------
# Unset -> voice drill disabled; the rest of the loop is unaffected.
# [LIVE voice] both required for the realtime AI-prospect drill.
ELEVENLABS_API_KEY=
# The ElevenLabs Agent configured with Claude as the LLM (the "AI prospect").
ELEVENLABS_AGENT_ID=

# --- Circleback recorder (DEFERRED, SPEC §15) ------------------------------
# No shared env secret. The Circleback secret is now PER-USER (SPEC §6.8, §18.1):
# each user sets their own in Settings, stored via SecretStore (ref in
# user_integration). v1 ingestion is manual paste/upload.
